<%- include("../../views/partials/user-header") %>

<style>
    .success-container {
        margin-top: 80px;
        margin-bottom: 100px;
        text-align: center;
    }
    .success-icon {
        font-size: 80px;
        color: #27ae60;
        margin-bottom: 30px;
    }
    .success-title {
        font-weight: 900;
        text-transform: uppercase;
        font-size: 36px;
        margin-bottom: 20px;
    }
    .success-message {
        color: #666;
        font-size: 18px;
        margin-bottom: 40px;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }
    .order-id-box {
        background: #f9f9f9;
        padding: 20px;
        border-radius: 12px;
        display: inline-block;
        margin-bottom: 50px;
        border: 1px dashed #ddd;
    }
    .order-id-label {
        display: block;
        font-size: 12px;
        text-transform: uppercase;
        font-weight: 700;
        color: #999;
        margin-bottom: 5px;
    }
    .order-id-value {
        font-weight: 800;
        font-size: 20px;
        color: #000;
    }
    .btn-continue {
        background: #000;
        color: #fff;
        padding: 15px 40px;
        border-radius: 8px;
        font-weight: 800;
        text-transform: uppercase;
        text-decoration: none;
        transition: 0.3s;
        display: inline-block;
    }
    .btn-continue:hover {
        background: #333;
        color: #fff;
        transform: translateY(-2px);
    }
</style>

<div class="container success-container">
    <div class="success-icon">
        <i class="fa-solid fa-circle-check"></i>
    </div>
    <h1 class="success-title">Order Placed Successfully!</h1>
    <p class="success-message">
        Thank you for your purchase. Your order has been received and is being processed. 
        
    </p>

    <% if (order) { %>
        <div class="order-id-box">
            <span class="order-id-label">Order Reference</span>
            <span class="order-id-value">#<%= order.orderId %></span>
        </div>
    <% } %>

    <div class="d-block">
        <a href="/shop" class="btn-continue">Continue Shopping</a>
    </div>
</div>

<%- include("../../views/partials/user-footer") %>
