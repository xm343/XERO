<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password | XERO</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/login.css">
    <style>
        .login-image-side {
            background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/change-password.png');
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-image-side">
            <div class="image-header">
                <img src="/images/xero-logo.png" alt="XERO" class="img-logo">
                <img src="/images/misfits-text.png" alt="Made for the Misfits" class="misfits-text">
            </div>
        </div>

        <div class="login-form-side">
            <h1>RESET PASSWORD</h1>
            <p class="text-muted mb-4">Create a new password for your account.</p>

            <% if (locals.message) { %>
                <div class="alert alert-danger" style="font-size: 0.9rem; padding: 10px; border-radius: 8px;">
                    <%= message %>
                </div>
            <% } %>

            <form id="resetForm" action="/reset-password" method="POST" novalidate>
                <div id="error-pass1" class="error-message"></div>
                <div class="form-group">
                    <input type="password" name="pass1" id="pass1" class="form-control" placeholder="NEW PASSWORD">
                </div>

                <div id="error-pass2" class="error-message"></div>
                <div class="form-group">
                    <input type="password" name="pass2" id="pass2" class="form-control" placeholder="CONFIRM PASSWORD">
                </div>

                <div class="btn-login-container">
                    <button type="submit" class="btn btn-login">RESET PASSWORD</button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const resetForm = document.getElementById('resetForm');
            const pass1 = document.getElementById('pass1');
            const pass2 = document.getElementById('pass2');
            const errorPass1 = document.getElementById('error-pass1');
            const errorPass2 = document.getElementById('error-pass2');

            resetForm.addEventListener('submit', function (e) {
                let isValid = true;
                
                if (pass1.value.length < 8) {
                    errorPass1.innerHTML = 'Password must be at least 8 characters';
                    errorPass1.style.display = 'block';
                    isValid = false;
                } else {
                    errorPass1.style.display = 'none';
                }

                if (pass1.value !== pass2.value) {
                    errorPass2.innerHTML = 'Passwords do not match';
                    errorPass2.style.display = 'block';
                    isValid = false;
                } else {
                    errorPass2.style.display = 'none';
                }

                if (!isValid) {
                    e.preventDefault();
                }
            });
        });
    </script>
</body>
</html>
