<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logged Out | XERO</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/login.css">
    <style>
        .login-image-side {
            background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/logout-bg.png');
        }
    </style>
</head>
<body>

    <div class="login-container">
        <!-- Left Side: Image -->
        <div class="login-image-side">
            <div class="image-header">
                <img src="/images/xero-logo.png" alt="XERO" class="img-logo">
                <img src="/images/misfits-text.png" alt="Made for the Misfits" class="misfits-text">
            </div>
        </div>

        <!-- Right Side: Content -->
        <div class="login-form-side">
            <div class="text-center">
                <div class="mb-4">
                    <i class="fa-solid fa-circle-check text-success" style="font-size: 4rem;"></i>
                </div>
                <h1 class="mb-3">YOU'VE LOGGED OUT</h1>
                <p class="text-muted mb-5">Thank you for visiting XERO. We hope to see you back soon!</p>

                <div class="btn-login-container">
                    <a href="/login" class="btn btn-login">LOGIN AGAIN</a>
                </div>

                <div class="signup-link-text mt-4">
                    Want to keep browsing? <a href="/">Go to Home...</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</body>
</html>
