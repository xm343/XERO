<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP | XERO</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/login.css">
    <style>
        .login-image-side {
            background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/confirm.jpg');
        }
        .otp-input {
            letter-spacing: 15px;
            font-size: 24px;
            text-align: center;
        }
        .otp-timer {
            font-weight: 600;
            color: #d9534f;
            margin-top: 10px;
            font-size: 14px;
        }
        .resend-link.disabled {
            color: #999;
            pointer-events: none;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-image-side">
            <div class="image-header">
                <img src="/images/xero-logo.png" alt="XERO" class="img-logo">
                <img src="/images/misfits-text.png" alt="Made for the Misfits" class="misfits-text">
            </div>
        </div>

        <div class="login-form-side">
            <h1>VERIFY OTP</h1>
            <p class="text-muted mb-4">An OTP has been sent to your email. Please enter it below to proceed.</p>

            <div id="alert-container"></div>

            <form id="otpForm" novalidate>
                <div id="error-otp" class="error-message"></div>
                <div class="form-group">
                    <input type="text" name="otp" id="otp" class="form-control otp-input" maxlength="6" placeholder="******">
                </div>

                <div class="btn-login-container">
                    <button type="submit" class="btn btn-login">VERIFY</button>
                </div>
            </form>

            <div class="signup-link-text">
                <div id="otpTimer" class="otp-timer">Resend OTP in <span id="timerValue">60</span>s</div>
                <a href="#" id="resendOtp" class="resend-link disabled">Resend OTP</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const otpForm = document.getElementById('otpForm');
            const otpInput = document.getElementById('otp');
            const errorOtp = document.getElementById('error-otp');
            const resendOtpBtn = document.getElementById('resendOtp');
            const timerValue = document.getElementById('timerValue');
            const otpTimerElement = document.getElementById('otpTimer');

            let timeLeft = 60;
            let timerId;

            function startTimer() {
                timeLeft = 60;
                resendOtpBtn.classList.add('disabled');
                otpTimerElement.style.display = 'block';
                
                timerId = setInterval(() => {
                    timeLeft--;
                    timerValue.textContent = timeLeft;
                    
                    if (timeLeft <= 0) {
                        clearInterval(timerId);
                        resendOtpBtn.classList.remove('disabled');
                        otpTimerElement.style.display = 'none';
                    }
                }, 1000);
            }

            startTimer();

            otpForm.addEventListener('submit', async function (e) {
                e.preventDefault();
                const otp = otpInput.value.trim();
                
                if (otp.length !== 6 || isNaN(otp)) {
                    errorOtp.innerHTML = 'Enter a valid 6-digit OTP';
                    errorOtp.style.display = 'block';
                    return;
                } else {
                    errorOtp.style.display = 'none';
                }

                try {
                    const response = await fetch('/verify-forgot-otp', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ otp })
                    });
                    const data = await response.json();
                    
                    if (data.success) {
                        window.location.href = data.redirectUrl;
                    } else {
                        errorOtp.innerHTML = data.message;
                        errorOtp.style.display = 'block';
                    }
                } catch (error) {
                    console.error('Error:', error);
                    errorOtp.innerHTML = 'Something went wrong. Please try again.';
                    errorOtp.style.display = 'block';
                }
            });

            resendOtpBtn.addEventListener('click', async function (e) {
                e.preventDefault();
                if (resendOtpBtn.classList.contains('disabled')) return;

                try {
                    const response = await fetch('/resend-otp', { method: 'POST' });
                    const data = await response.json();
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'OTP Resent',
                            text: 'A new OTP has been sent to your email.',
                            showConfirmButton: false,
                            timer: 1500
                        });
                        startTimer();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message
                        });
                    }
                } catch (error) {
                    console.error('Error:', error);
                }
            });
        });
    </script>
</body>
</html>
