<%- include("../../views/partials/user-header") %>

<style>
    .breadcrumb-wrap {
        background-color: #f9f9f9;
        padding: 15px 0;
        margin-bottom: 50px;
    }
    .breadcrumb-item a {
        color: #666;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
    }
    .breadcrumb-item.active {
        color: #000;
        font-weight: 700;
        font-size: 14px;
    }

    .wishlist-container {
        margin-bottom: 100px;
    }
    .wishlist-title {
        font-size: 36px;
        font-weight: 900;
        margin-bottom: 40px;
        text-transform: uppercase;
        border-bottom: 2px solid #000;
        padding-bottom: 10px;
        display: inline-block;
    }

    .wishlist-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 15px;
    }
    .wishlist-table th {
        text-transform: uppercase;
        font-weight: 800;
        font-size: 13px;
        color: #999;
        padding: 0 20px 10px;
        border: none;
    }
    .wishlist-item {
        background: #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border-radius: 12px;
        transition: 0.3s;
    }
    .wishlist-item:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }
    .wishlist-item td {
        padding: 20px;
        vertical-align: middle;
    }
    .wishlist-item td:first-child {
        border-radius: 12px 0 0 12px;
    }
    .wishlist-item td:last-child {
        border-radius: 0 12px 12px 0;
    }

    .product-img {
        width: 100px;
        height: 100px;
        object-fit: contain;
        background: #f4f4f4;
        border-radius: 8px;
    }
    .product-info h5 {
        font-weight: 800;
        margin-bottom: 5px;
        text-transform: uppercase;
    }
    .product-category {
        font-size: 12px;
        color: #999;
        text-transform: uppercase;
        font-weight: 600;
    }

    .price {
        font-weight: 800;
        font-size: 18px;
    }
    .stock-status {
        font-weight: 700;
        font-size: 14px;
    }
    .in-stock { color: #27ae60; }
    .out-of-stock { color: #e74c3c; }

    .action-btns {
        display: flex;
        gap: 10px;
    }
    .btn-add-cart {
        background: #000;
        color: #fff;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 12px;
        transition: 0.3s;
    }
    .btn-add-cart:hover {
        background: #333;
    }
    .btn-remove {
        background: #f4f4f4;
        color: #e74c3c;
        border: none;
        width: 38px;
        height: 38px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }
    .wishlist-item:hover .btn-remove {
        background: #ffebeb;
    }

    .empty-wishlist {
        text-align: center;
        padding: 100px 0;
    }
    .empty-wishlist i {
        font-size: 80px;
        color: #eee;
        margin-bottom: 20px;
    }
    .empty-wishlist h3 {
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 15px;
    }
    .btn-shop-now {
        display: inline-block;
        background: #000;
        color: #fff;
        padding: 15px 40px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 20px;
        transition: 0.3s;
    }
    .btn-shop-now:hover {
        background: #333;
        color: #fff;
    }
</style>

<div class="breadcrumb-wrap">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Wishlist</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container wishlist-container">
    <h1 class="wishlist-title">My Wishlist</h1>

    <% if (wishlist && wishlist.length > 0) { %>
        <div class="table-responsive">
            <table class="wishlist-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Stock Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% wishlist.forEach(item => { %>
                        <% if (item.productsId) { %>
                            <tr class="wishlist-item" id="wishlist-row-<%= item.productsId._id %>">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <a href="/productDetails?id=<%= item.productsId._id %>">
                                            <img src="/uploads/re-image/<%= item.productsId.productImage[0] %>" alt="<%= item.productsId.productName %>" class="product-img me-3">
                                        </a>
                                        <div class="product-info">
                                            <a href="/productDetails?id=<%= item.productsId._id %>" class="text-dark text-decoration-none">
                                                <h5><%= item.productsId.productName %></h5>
                                            </a>
                                            <span class="product-category"><%= item.productsId.category ? item.productsId.category.name : 'Uncategorized' %></span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="price">₹<%= item.productsId.salesPrice %></span>
                                </td>
                                <td>
                                    <span class="stock-status <%= item.productsId.quantity > 0 ? 'in-stock' : 'out-of-stock' %>">
                                        <%= item.productsId.quantity > 0 ? 'In Stock' : 'Out of Stock' %>
                                    </span>
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <button class="btn-add-cart" onclick="addToCart('<%= item.productsId._id %>')">
                                            Add to Cart
                                        </button>
                                        <button class="btn-remove" onclick="removeFromWishlist('<%= item.productsId._id %>')" title="Remove">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="empty-wishlist">
            <i class="fa-regular fa-heart"></i>
            <h3>Your wishlist is empty</h3>
            <p class="text-muted">Looks like you haven't added anything to your wishlist yet.</p>
            <a href="/shop" class="btn-shop-now">Start Shopping</a>
        </div>
    <% } %>
</div>

<script>
    async function removeFromWishlist(productId) {
        try {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: "You want to remove this item from wishlist!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#000',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, remove it!'
            });

            if (result.isConfirmed) {
                const response = await fetch('/removeFromWishlist', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ productId })
                });

                const data = await response.json();

                if (data.status === true) {
                    Swal.fire(
                        'Removed!',
                        'Product has been removed from your wishlist.',
                        'success'
                    ).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error!', data.message || 'Something went wrong', 'error');
                }
            }
        } catch (error) {
            console.error('Error removing from wishlist:', error);
            Swal.fire('Error!', 'Something went wrong', 'error');
        }
    }
</script>

<%- include("../../views/partials/user-footer") %>
