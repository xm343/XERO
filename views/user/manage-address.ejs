<%- include("../../views/partials/user-header") %>

<style>
    .profile-card {
        background: #fff;
        border: 1px solid #f0f0f0;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 30px;
        transition: all 0.3s ease;
    }
    .profile-sidebar {
        background: #f9f9f9;
        border-right: 1px solid #eee;
        height: 100%;
        padding: 40px 25px;
    }
    .nav-link-custom {
        font-weight: 700;
        color: #666;
        text-transform: uppercase;
        font-size: 13px;
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 8px;
        display: block;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        letter-spacing: 0.5px;
    }
    .nav-link-custom:hover {
        background: #f0f0f0;
        color: #000;
        transform: translateX(5px);
    }
    .nav-link-custom.active {
        background: #000;
        color: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .profile-content {
        padding: 50px;
    }
    .section-header {
        font-weight: 900;
        text-transform: uppercase;
        font-size: 26px;
        margin-bottom: 35px;
        letter-spacing: 1px;
        color: #000;
        position: relative;
    }
    .section-header::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 50px;
        height: 4px;
        background: #000;
    }
    .address-card {
        border: 1.5px solid #eee;
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 20px;
        transition: all 0.3s ease;
        position: relative;
    }
    .address-card:hover {
        border-color: #000;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }
    .address-type {
        display: inline-block;
        padding: 5px 12px;
        background: #f0f0f0;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 15px;
        letter-spacing: 0.5px;
    }
    .address-name {
        font-weight: 800;
        font-size: 18px;
        margin-bottom: 10px;
    }
    .address-details {
        color: #666;
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 20px;
    }
    .address-actions {
        display: flex;
        gap: 15px;
    }
    .btn-action {
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        text-decoration: none;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }
    .btn-edit {
        color: #000;
    }
    .btn-delete {
        color: #dc3545;
    }
    .btn-add-address {
        background: #000;
        color: #fff;
        font-weight: 800;
        text-transform: uppercase;
        padding: 15px 30px;
        border-radius: 10px;
        text-decoration: none;
        display: inline-block;
        letter-spacing: 1px;
        font-size: 12px;
        transition: all 0.3s ease;
    }
    .btn-add-address:hover {
        background: #333;
        color: #fff;
        transform: translateY(-2px);
    }
    .avatar-placeholder {
        width: 100px;
        height: 100px;
        background: #000;
        color: #fff;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        font-weight: 900;
        margin: 0 auto 20px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
</style>

<div class="container my-5 pt-4">
    <div class="profile-card shadow-sm">
        <div class="row g-0">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="profile-sidebar text-center">
                    <div class="avatar-placeholder">
                        <%= user.name.charAt(0).toUpperCase() %>
                    </div>
                    <h5 class="fw-bold mb-1"><%= user.name %></h5>
                    <p class="text-muted small mb-4"><%= user.email %></p>
                    
                    <nav class="text-start mt-4">
                        <a href="/user-profile" class="nav-link-custom">
                            <i class="fa-solid fa-user me-2"></i> Profile Overview
                        </a>
                        <a href="/my-orders" class="nav-link-custom">
                            <i class="fa-solid fa-box me-2"></i> My Orders
                        </a>
                        <a href="/manage-address" class="nav-link-custom active">
                            <i class="fa-solid fa-location-dot me-2"></i> My Addresses
                        </a>
                        <a href="/wallet" class="nav-link-custom">
                            <i class="fa-solid fa-wallet me-2"></i> Wallet
                        </a>
                        <a href="/change-password" class="nav-link-custom">
                            <i class="fa-solid fa-lock me-2"></i> Security
                        </a>
                        <a href="/logout" class="nav-link-custom text-danger">
                            <i class="fa-solid fa-right-from-bracket me-2"></i> Logout
                        </a>
                    </nav>
                </div>
            </div>
            
            <!-- Content -->
            <div class="col-lg-9">
                <div class="profile-content">
                    <div class="d-flex justify-content-between align-items-center mb-5">
                        <h2 class="section-header mb-0">My Addresses</h2>
                        <a href="/add-address" class="btn-add-address">Add New Address</a>
                    </div>
                    
                    <div class="row">
                        <% if (address && address.length > 0) { %>
                            <% address.forEach(item => { %>
                                <div class="col-md-6">
                                    <div class="address-card">
                                        <div class="address-type"><%= item.addressType %></div>
                                        <div class="address-name"><%= item.name %></div>
                                        <div class="address-details">
                                            <%= item.landMark %>, <%= item.city %>, <%= item.district %><br>
                                            <%= item.state %> - <%= item.pincode %><br>
                                            Phone: <%= item.phone %><br>
                                            Alt: <%= item.altPhone %>
                                        </div>
                                        <div class="address-actions">
                                            <a href="/edit-address?id=<%= item._id %>" class="btn-action btn-edit">Edit</a>
                                            <a href="/delete-address?id=<%= item._id %>" class="btn-action btn-delete" onclick="return confirm('Are you sure you want to delete this address?')">Delete</a>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center py-5">
                                <i class="fa-solid fa-map-location-dot fa-3x text-light mb-3"></i>
                                <p class="text-muted">No addresses saved yet.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../../views/partials/user-footer") %>
