<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP | XERO</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Custom CSS (Reusing signup.css for layout) -->
    <link rel="stylesheet" href="/css/signup.css">
    <style>
        .signup-image-side {
            background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/images/confirm.jpg');
        }
        .otp-input-container {
            margin-top: 20px;
        }
        .resend-link {
            text-align: right;
            margin-top: 10px;
        }
        .resend-link a {
            color: #0000ff;
            text-decoration: none;
            font-weight: 700;
        }
        .error-message {
            display: block;
            color: red;
            font-size: 0.85rem;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <div class="signup-container">
        <!-- Left Side: Image -->
        <div class="signup-image-side">
        </div>

        <!-- Right Side: Form -->
        <div class="signup-form-side">
            <h1>VERIFY OTP</h1>
            <p>Please enter the 6-digit OTP sent to your email.</p>

            <% if (locals.message) { %>
                <div class="error-message"><%= message %></div>
            <% } %>

            <form action="/verify-otp" method="POST">
                <div class="form-group otp-input-container">
                    <input type="text" name="otp" class="form-control text-center" placeholder="ENTER OTP" maxlength="6" required>
                </div>

                <div class="btn-signup-container">
                    <button type="submit" class="btn btn-signup">VERIFY</button>
                </div>
            </form>

            <div class="resend-link">
                Didn't receive code? <a href="/resend-otp">Resend Now...</a>
            </div>
            
            <!-- <div class="login-link-text mt-4">
                Back to <a href="/signup">Signup</a>
            </div> -->
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
