<%- include("../../views/partials/user-header") %>

<style>
    .breadcrumb-wrap {
        background-color: #f9f9f9;
        padding: 15px 0;
        margin-bottom: 50px;
    }
    .breadcrumb-item a {
        color: #666;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
    }
    .breadcrumb-item.active {
        color: #000;
        font-weight: 700;
        font-size: 14px;
    }
    
    .product-details-container {
        margin-bottom: 100px;
    }

    .product-image-gallery {
        position: sticky;
        top: 100px;
    }
    .main-image-container {
        background: #f4f4f4;
        border-radius: 15px;
        margin-bottom: 20px;
        overflow: hidden;
        height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .main-image-container img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }
    .main-image-container:hover img {
        transform: scale(1.1);
    }
    .thumbnail-container {
        display: flex;
        gap: 15px;
        overflow-x: auto;
        padding-bottom: 10px;
    }
    .thumbnail {
        width: 80px;
        height: 80px;
        background: #f4f4f4;
        border-radius: 8px;
        cursor: pointer;
        padding: 5px;
        border: 2px solid transparent;
        flex-shrink: 0;
    }
    .thumbnail.active {
        border-color: #000;
    }
    .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .product-info {
        padding-left: 30px;
    }
    .product-brand {
        font-weight: 700;
        color: #999;
        text-transform: uppercase;
        font-size: 14px;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }
    .product-title {
        font-size: 36px;
        font-weight: 900;
        margin-bottom: 15px;
        text-transform: uppercase;
    }
    .product-rating {
        margin-bottom: 20px;
        color: #ffc107;
    }
    .product-rating span {
        color: #999;
        margin-left: 10px;
        font-size: 14px;
    }
    .product-price {
        display: flex;
        align-items: baseline;
        gap: 15px;
        margin-bottom: 25px;
    }
    .sales-price {
        font-size: 28px;
        font-weight: 900;
    }
    .regular-price {
        font-size: 20px;
        text-decoration: line-through;
        color: #999;
    }
    .offer-badge {
        background: #e74c3c;
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
    }
    .product-meta {
        margin-bottom: 30px;
        padding: 20px 0;
        border-top: 1px solid #eee;
        border-bottom: 1px solid #eee;
    }
    .meta-item {
        display: flex;
        margin-bottom: 10px;
        font-size: 15px;
    }
    .meta-label {
        font-weight: 700;
        width: 120px;
        color: #666;
    }
    .meta-value {
        font-weight: 600;
    }
    .stock-status {
        font-weight: 700;
    }
    .in-stock { color: #27ae60; }
    .out-of-stock { color: #e74c3c; }

    .product-description {
        margin-bottom: 40px;
    }
    .product-description h4 {
        font-weight: 800;
        margin-bottom: 15px;
        font-size: 18px;
        text-transform: uppercase;
    }
    .product-description p {
        color: #666;
        line-height: 1.8;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
    }
    .btn-add-cart {
        flex: 1;
        background: #000;
        color: #fff;
        border: 2px solid #000;
        padding: 15px;
        font-weight: 800;
        text-transform: uppercase;
        border-radius: 8px;
        transition: 0.3s;
    }
    .btn-add-cart:hover {
        background: transparent;
        color: #000;
    }
    .btn-buy-now {
        flex: 1;
        background: #e67e22;
        color: #fff;
        border: 2px solid #e67e22;
        padding: 15px;
        font-weight: 800;
        text-transform: uppercase;
        border-radius: 8px;
        transition: 0.3s;
    }
    .btn-buy-now:hover {
        background: transparent;
        color: #e67e22;
    }
    .btn-wishlist {
        width: 55px;
        height: 55px;
        background: #f4f4f4;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 20px;
        transition: 0.3s;
    }
    .btn-wishlist:hover {
        background: #eee;
        color: #e74c3c;
    }
</style>

<div class="breadcrumb-wrap">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                <li class="breadcrumb-item active" aria-current="page"><%= product.productName %></li>
            </ol>
        </nav>
    </div>
</div>

<div class="container product-details-container">
    <div class="row">
        <!-- Product Images -->
        <div class="col-lg-6">
            <div class="product-image-gallery">
                <div class="main-image-container" id="mainImageContainer">
                    <img src="/uploads/re-image/<%= product.productImage[0] %>" alt="<%= product.productName %>" id="mainImage">
                </div>
                <div class="thumbnail-container">
                    <% product.productImage.forEach((img, index) => { %>
                        <div class="thumbnail <%= index === 0 ? 'active' : '' %>" onclick="changeImage(this, '<%= img %>')">
                            <img src="/uploads/re-image/<%= img %>" alt="Thumbnail <%= index + 1 %>">
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Product Details -->
        <div class="col-lg-6">
            <div class="product-info">
                <div class="product-brand"><%= product.brand %></div>
                <h1 class="product-title"><%= product.productName %></h1>
                
                <div class="product-rating">
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-regular fa-star"></i>
                    <span>(15 Reviews)</span>
                </div>

                <div class="product-price">
                    <span class="sales-price">₹<%= product.salesPrice %></span>
                    <% if (product.regularPrice > product.salesPrice) { %>
                        <span class="regular-price">₹<%= product.regularPrice %></span>
                        <span class="offer-badge"><%= Math.round(((product.regularPrice - product.salesPrice) / product.regularPrice) * 100) %>% OFF</span>
                    <% } %>
                </div>

                <div class="product-meta">
                    <div class="meta-item">
                        <span class="meta-label">Category:</span>
                        <span class="meta-value"><%= category.name %></span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Color:</span>
                        <span class="meta-value"><%= product.color %></span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Availability:</span>
                        <span class="meta-value stock-status <%= product.quantity > 0 ? 'in-stock' : 'out-of-stock' %>">
                            <%= product.quantity > 0 ? 'In Stock (' + product.quantity + ')' : 'Out of Stock' %>
                        </span>
                    </div>
                </div>

                <div class="product-description">
                    <h4>Description</h4>
                    <p><%= product.description %></p>
                </div>

                <div class="action-buttons">
                    <button class="btn-add-cart" onclick="addToCart('<%= product._id %>')">
                        <i class="fa-solid fa-cart-shopping me-2"></i> Add to Cart
                    </button>
                    <button class="btn-buy-now" onclick="buyNow('<%= product._id %>')">
                        <i class="fa-solid fa-bolt me-2"></i> Buy Now
                    </button>
                    <button class="btn-wishlist" onclick="addToWishlist('<%= product._id %>', this)">
                        <i class="fa-regular fa-heart"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function changeImage(element, imageName) {
        document.getElementById('mainImage').src = '/uploads/re-image/' + imageName;
        
        // Update active thumbnail
        const thumbnails = document.querySelectorAll('.thumbnail');
        thumbnails.forEach(t => t.classList.remove('active'));
        element.classList.add('active');
    }

    function buyNow(productId) {
        console.log('Buy Now clicked for product:', productId);
        // Implement buy now logic (e.g., add to cart and redirect to checkout)
        // For now, we'll just redirect to cart if it existed, or alert
        alert('Redirecting to checkout for product: ' + productId);
    }
</script>

<%- include("../../views/partials/user-footer") %>
