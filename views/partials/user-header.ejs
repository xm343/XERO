<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary-black: #000000;
            --accent-gray: #f4f4f4;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fff;
            color: var(--primary-black);
        }

        /* Navbar Styling */
        .navbar {
            padding: 25px 0;
            background: #fff;
            border-bottom: 1px solid #eee;
        }
        .navbar-brand img {
            height: 45px;
        }
        .nav-link {
            font-weight: 700;
            color: #000 !important;
            margin: 0 15px;
            text-transform: uppercase;
            font-size: 13px;
            letter-spacing: 1px;
        }
        .nav-icons a {
            color: #000;
            margin-left: 25px;
            font-size: 20px;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="/images/xero-logo.png" alt="XERO">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a href="/" class="nav-link">Home</a></li>
                    <li class="nav-item"><a href="/shop" class="nav-link">Shop</a></li>
                </ul>
                <div class="nav-icons d-flex align-items-center">
                    <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
                    <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
                    <% if (user) { %>
                        <div class="dropdown ms-3">
                            <a class="dropdown-toggle text-decoration-none fw-bold text-dark" href="#" role="button" data-bs-toggle="dropdown">
                                <%= user.name %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item py-2" href="/user-profile">Profile</a></li>
                                <li><a class="dropdown-item py-2" href="/logout">Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/login"><i class="fa-regular fa-user"></i></a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>
